# Normalize line endings in text files to LF in the repository
* text=auto eol=lf

# Keep Windows-specific scripts as CRLF where expected
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Treat common binary assets as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.tgz binary
*.jar binary
*.woff binary
*.woff2 binary
