# prod.tfvars.example — copy to scripts/prod.tfvars and fill in real values.
# NEVER commit scripts/prod.tfvars — it is git-ignored.
#
# Non-secret variables (project, location, model config, AKS config, instance list)
# are stored centrally in Azure Blob Storage and downloaded automatically by
# terraform-local.sh before each Terraform run:
#   blob path: {TFSTATE_CONTAINER}/tfvars/prod.auto.tfvars
# See scripts/central-tfvars.example for the required format.
#
# Azure Service Principal credentials
AZURE_TENANT_ID     = "<tenant-id>"
AZURE_SUBSCRIPTION_ID = "<subscription-id>"
AZURE_CLIENT_ID     = "<client-id>"
AZURE_CLIENT_SECRET = "<client-secret>"

# Terraform remote state backend (matches backend.prod.hcl)
TFSTATE_RG               = "<prod-tfstate-resource-group-name>"
TFSTATE_LOCATION         = "<azure-region>"
TFSTATE_STORAGE_ACCOUNT  = "<prod-tfstate-storage-account-name>"
TFSTATE_CONTAINER        = "<prod-tfstate-container-name>"
TFSTATE_KEY              = "terraform-prod.tfstate"

# Terraform input variables — sensitive (must never appear in the central tfvars blob)
TF_VAR_public_ip          = "<your-home-ip>/32"
TF_VAR_budget_alert_email = "<your-email>"
TF_VAR_azure_ai_api_key   = "<azure-ai-foundry-api-key>"
